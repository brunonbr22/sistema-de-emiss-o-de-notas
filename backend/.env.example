NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://mfmei:changeme@localhost:5432/mfmei_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret_256bits
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:5173

# Focus NFe
FOCUS_NFE_TOKEN=seu_token_aqui
FOCUS_NFE_ENV=homologacao   # homologacao | producao

# Storage
STORAGE_DRIVER=local
STORAGE_PATH=./storage          # caminho local para armazenar XML/PDF

# Pagamentos
WEBHOOK_SECRET=troque_por_um_secret_forte

# SMTP
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=no-reply@mfmei.com.br
SMTP_PASS=changeme
