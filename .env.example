# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=mfmei
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mfmei_db
DATABASE_URL=postgresql://mfmei:changeme@postgres:5432/mfmei_db

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_256bits
JWT_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Focus NFe ────────────────────────────────────────────────
FOCUS_NFE_TOKEN=seu_token_aqui
FOCUS_NFE_BASE_URL=https://homologacao.focusnfe.com.br

# ─── NFS-e ────────────────────────────────────────────────────
# Configurado por município no painel

# ─── Storage (XML) ────────────────────────────────────────────
STORAGE_DRIVER=local
# Para S3:
# STORAGE_DRIVER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=sa-east-1
# AWS_BUCKET=mfmei-xmls

# ─── Email ────────────────────────────────────────────────────
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=no-reply@mfmei.com.br
SMTP_PASS=changeme
