# Shared
NODE_ENV=development
JWT_SECRET=supersecret
JWT_REFRESH_SECRET=superrefreshsecret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emissor
REDIS_URL=redis://localhost:6379

# Focus NFe
FOCUS_NFE_API_URL=https://api.focusnfe.com.br
FOCUS_NFE_TOKEN=changeme

# NFS-e Padrão Nacional
NACIONAL_NFSE_API_URL=https://api-padrao-nacional.exemplo
NACIONAL_NFSE_TOKEN=changeme

# BrasilAPI
BRASIL_API_URL=https://brasilapi.com.br/api

# Cloudflare R2 / S3 compatible
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=xml-notas
R2_ACCESS_KEY_ID=changeme
R2_SECRET_ACCESS_KEY=changeme
R2_REGION=auto

# Frontend
VITE_API_URL=http://localhost:3000
